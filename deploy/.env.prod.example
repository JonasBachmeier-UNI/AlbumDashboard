# Production config for docker-compose.prod.yml.
# On the server, copy this to a file named `.env` in the project root
# (/home/bachi/albumtracker/.env) and fill in real values. It is gitignored.

# Postgres password for the bundled db container. Use something strong.
POSTGRES_PASSWORD=change-me-to-something-strong

# Connection string the app/poller use. Host is the compose service name `db`.
# The password here MUST match POSTGRES_PASSWORD above.
DATABASE_URL=postgres://album:change-me-to-something-strong@db:5432/albumdashboard

# Last.fm credentials (same as your dev .env).
LASTFM_API_KEY=50404a00f4d9d0cc28a05f144a039318
LASTFM_USER=J0n455

# Host port the app is published on. Your reverse proxy points the subdomain
# here. Pick one that's free on the server (the other project uses its own).
APP_PORT=4101

# Reverse-proxy this app at album.jonasbachmeier.de
#
# 1. Point a DNS A record for album.jonasbachmeier.de at the server.
# 2. Put this file at /etc/nginx/sites-available/album.conf
#    (the proxy_pass port must match APP_PORT in your .env).
# 3. Enable + reload:
#      sudo ln -s /etc/nginx/sites-available/album.conf /etc/nginx/sites-enabled/
#      sudo nginx -t && sudo systemctl reload nginx
# 4. Add TLS (free): sudo certbot --nginx -d album.jonasbachmeier.de
#    Certbot rewrites this block to listen on 443 and redirect 80→443.

server {
    listen 80;
    server_name album.jonasbachmeier.de;

    location / {
        proxy_pass http://127.0.0.1:4101;   # APP_PORT
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

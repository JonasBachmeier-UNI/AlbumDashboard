# Copy to .env and fill in. Used by the server-side poller, backfill, and API.

# Postgres connection string
DATABASE_URL=postgres://album:album@localhost:5433/albumdashboard

# Last.fm credentials — get a free API key at https://www.last.fm/api/account/create
LASTFM_API_KEY=your_api_key_here
LASTFM_USER=your_lastfm_username
